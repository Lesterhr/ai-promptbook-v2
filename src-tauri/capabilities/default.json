{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "fs:default",
      "allow": [
        { "path": "$HOME/.ai-promptbook/**" },
        { "path": "$RESOURCE/**" }
      ]
    },
    "fs:allow-exists",
    "fs:allow-read-dir",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "git", "cmd": "git", "args": true }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "git", "cmd": "git", "args": true }
      ]
    }
  ]
}
